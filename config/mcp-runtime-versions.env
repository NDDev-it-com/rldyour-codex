# Pinned runtime package versions for reproducible MCP startup.
# Update intentionally after validating the matching MCP capability smoke.
# Dart/Flutter MCP is provided by the local Dart SDK rather than a package pin.
DART_FLUTTER_MCP_RUNTIME=external-local-dart-sdk
NODE_MAJOR_VERSION=24
BUN_VERSION=1.3.14
DART_SDK_VERSION=3.12.0
CODEX_CLI_VERSION=0.136.0
GITHUB_MCP_SERVER_VERSION=1.1.2
MCP_PYTHON_SDK_VERSION=1.27.2
SERENA_AGENT_VERSION=1.5.3
SEQUENTIAL_THINKING_MCP_VERSION=2025.12.18
PLAYWRIGHT_MCP_VERSION=0.0.75
CHROME_DEVTOOLS_MCP_VERSION=1.1.1
CONTEXT7_MCP_VERSION=3.0.0
SHADCN_VERSION=4.9.0

# CI-only security scanner pin. This is not an MCP runtime dependency.
SEMGREP_CLI_VERSION=1.164.0
