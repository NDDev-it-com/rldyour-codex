{
  "schema_version": 1,
  "adapter": "codex",
  "public_repository": "https://github.com/NDDev-it-com/rldyour-codex",
  "license": "AGPL-3.0-or-later",
  "plugins": [
    "rldyour-browser",
    "rldyour-design",
    "rldyour-explore",
    "rldyour-flow",
    "rldyour-lsps",
    "rldyour-mcps",
    "rldyour-orchestrator",
    "rldyour-rtk",
    "rldyour-rules",
    "rldyour-security",
    "rldyour-serena-mcp"
  ],
  "skills": {
    "count": 45,
    "names": [
      "architecture-boundaries",
      "browser-debug",
      "browser-tool-routing",
      "browser-validation",
      "cmux-orchestrator",
      "cmux-worker",
      "dependency-compatibility-policy",
      "design-system-implementation",
      "design-validation",
      "figma-to-code",
      "flow-architecture-review",
      "flow-consistency-review",
      "flow-integration-review",
      "flow-post-task-sync",
      "flow-quality-review",
      "flow-security-review",
      "flow-verification-review",
      "fsd-frontend-architecture",
      "implementation-discipline",
      "instruction-docs-sync",
      "lsp-health-check",
      "lsp-routing",
      "lsp-setup",
      "owasp-top-10-implementation",
      "playwright-cli-validation",
      "project-instructions-policy",
      "quality-first-engineering",
      "ry-deploy",
      "ry-design",
      "ry-init",
      "ry-newp",
      "ry-repair",
      "ry-review",
      "ry-rules-review",
      "ry-sec-review",
      "ry-start",
      "serena-code-workflow",
      "serena-lsp-integration",
      "serena-memory-sync",
      "tech-research",
      "token-economy",
      "verification-quality-gates",
      "visual-diff-review",
      "web-research",
      "webwright-task"
    ],
    "reviewer_track_skills": [
      "flow-architecture-review",
      "flow-consistency-review",
      "flow-integration-review",
      "flow-quality-review",
      "flow-security-review",
      "flow-verification-review"
    ]
  },
  "slash_commands": {
    "count": 0,
    "policy": "Codex uses skills and managed subagents as the public invocation surface; slash commands are intentionally absent."
  },
  "agents": {
    "roles": {
      "agent.explore.research": "research-explorer",
      "agent.review.architecture": "architecture-reviewer",
      "agent.review.browser": "browser-tester",
      "agent.review.consistency": "consistency-reviewer",
      "agent.review.quality": "quality-reviewer",
      "agent.review.security": "security-audit",
      "agent.review.verification": "test-reviewer",
      "agent.sync.serena-memory": "serena-sync"
    }
  },
  "hooks": {
    "removed_plugin_hooks_feature_required": false,
    "hooks_feature_default_enabled": true,
    "plugin_bundled_hooks_discoverable": true,
    "plugin_hook_trust_required": true,
    "trusted_hook_hashes_refreshed_by_installer": true,
    "handler_type": "command",
    "lifecycles": {
      "prompt.submit.sync-required": {
        "plugin": "rldyour-serena-mcp",
        "event": "UserPromptSubmit",
        "command_contains": "hooks/user_prompt_submit.sh"
      },
      "session.start.context": {
        "plugin": "rldyour-flow",
        "event": "SessionStart",
        "command_contains": "hooks/session_start_dispatcher.sh"
      },
      "task.stop.memory-sync": {
        "plugin": "rldyour-serena-mcp",
        "event": "Stop",
        "command_contains": "hooks/stop_memory_sync.sh",
        "dispatched_by": "task.stop.sync"
      },
      "task.stop.sync": {
        "plugin": "rldyour-flow",
        "event": "Stop",
        "command_contains": "hooks/stop_lifecycle_dispatcher.sh"
      },
      "tool.post.commit-advice": {
        "plugin": "rldyour-flow",
        "event": "PostToolUse",
        "command_contains": "hooks/post_tool_use_commit_advice.sh"
      },
      "tool.post.sync-marker": {
        "plugin": "rldyour-serena-mcp",
        "event": "PostToolUse",
        "command_contains": "hooks/mark_sync_required.sh"
      },
      "tool.pre.env-protection": {
        "plugin": "rldyour-flow",
        "event": "PreToolUse",
        "command_contains": "hooks/pre_tool_use_cwd_guard.sh"
      },
      "tool.pre.git-policy": {
        "plugin": "rldyour-serena-mcp",
        "event": "PreToolUse",
        "command_contains": "hooks/prepare_auto_sync.sh"
      },
      "tool.pre.rtk-rewrite": {
        "plugin": "rldyour-rtk",
        "event": "PreToolUse",
        "command_contains": "hooks/rtk_rewrite.sh"
      }
    }
  },
  "mcp": {
    "profile": "rldyour-mcps",
    "servers": [
      "chrome-devtools",
      "context7",
      "dart-flutter",
      "deepwiki",
      "figma",
      "grep",
      "github",
      "openaiDeveloperDocs",
      "sequential-thinking",
      "serena",
      "shadcn"
    ],
    "required_servers": []
  },
  "security": {
    "default_profile": "rldyour-yolo",
    "permission_model": "legacy_sandbox",
    "permission_profiles_active": false,
    "default_sandbox_mode": "danger-full-access",
    "default_approval_policy": "never",
    "check_for_update_on_startup": false,
    "full_auto_standard": true,
    "full_auto_aliases": [
      "yolo",
      "full-auto",
      "dangerously-skip-permissions"
    ],
    "safe_profile": "rldyour-safe",
    "safe_profile_flag": "--safe-mode",
    "allow_repo_local_yolo_defaults": true
  },
  "cache": {
    "layout": "versioned",
    "path_template": "${CODEX_HOME}/plugins/cache/rldyour-codex/<plugin>/<version>"
  },
  "browser_providers": {
    "policy": "root config/browser-automation-policy.json",
    "disabled_codex_surfaces": {
      "plugins": [
        "browser@openai-bundled"
      ],
      "mcp_servers": [
        "computer-use",
        "node_repl"
      ]
    },
    "required_engine": {
      "name": "cloakbrowser",
      "version_pin": "CLOAKBROWSER_VERSION",
      "installer_owner": "rldyour-new-mac-or-ubuntu",
      "managed_wrapper": "~/.local/bin/chrome-devtools-mcp",
      "stock_chromium_fallback": false
    },
    "required_common_providers": [
      "playwright-cli",
      "chrome-devtools-mcp"
    ],
    "mcp_providers": [
      "chrome-devtools-mcp"
    ],
    "cli_providers": [
      "playwright-cli"
    ],
    "compatibility_skill_routes": {
      "webwright-task": [
        "playwright-cli",
        "chrome-devtools-mcp"
      ]
    },
    "skill_boundary": {
      "required_skills": [
        "browser-debug",
        "browser-tool-routing",
        "browser-validation",
        "playwright-cli-validation",
        "visual-diff-review",
        "webwright-task"
      ],
      "preflight": {
        "command": "$HOME/.local/bin/cloakbrowser-cdp-health",
        "before_every_browser_action": true,
        "failure_result": "NOT_PROVEN"
      },
      "playwright_cli": {
        "executable": "$HOME/.local/bin/playwright-cli",
        "forbidden_arguments": [
          "run-code",
          "--filename"
        ]
      },
      "chrome_devtools_mcp_transport": {
        "command": "/bin/sh",
        "args": [
          "-c",
          "exec \"$HOME/.local/bin/chrome-devtools-mcp\" --headless --isolated --no-usage-statistics --no-performance-crux"
        ]
      },
      "forbidden_surfaces": [
        "webwright-runtime",
        "stock-browser",
        "raw-browser",
        "in-app-browser",
        "browser_agent",
        "node_repl",
        "computer-use",
        "playwright-mcp",
        "raw-playwright",
        "bunx",
        "npx",
        "direct-provider-package",
        "alternate-cdp",
        "alternate-executable",
        "alternate-config",
        "fallback"
      ]
    }
  }
}
