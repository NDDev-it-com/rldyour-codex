# Guard common local credential paths from shell-level disclosure.

prefix_rule(
    pattern = ["cat", "~/.ssh/id_rsa"],
    decision = "forbidden",
    justification = "Do not print private SSH keys. Use ssh-agent or key fingerprints instead.",
    match = ["cat ~/.ssh/id_rsa"],
    not_match = ["cat ~/.ssh/id_rsa.pub"],
)

prefix_rule(
    pattern = ["cat", "~/.ssh/id_ed25519"],
    decision = "forbidden",
    justification = "Do not print private SSH keys. Use ssh-agent or key fingerprints instead.",
    match = ["cat ~/.ssh/id_ed25519"],
    not_match = ["cat ~/.ssh/id_ed25519.pub"],
)

prefix_rule(
    pattern = ["cat", "$HOME/.ssh/id_rsa"],
    decision = "forbidden",
    justification = "Do not print private SSH keys. Use ssh-agent or key fingerprints instead.",
    match = ["cat '$HOME/.ssh/id_rsa'"],
    not_match = ["cat '$HOME/.ssh/id_rsa.pub'"],
)

prefix_rule(
    pattern = ["cat", "$HOME/.ssh/id_ed25519"],
    decision = "forbidden",
    justification = "Do not print private SSH keys. Use ssh-agent or key fingerprints instead.",
    match = ["cat '$HOME/.ssh/id_ed25519'"],
    not_match = ["cat '$HOME/.ssh/id_ed25519.pub'"],
)

prefix_rule(
    pattern = ["cat", ".env"],
    decision = "prompt",
    justification = "Project env files may contain secrets; inspect only specific non-secret keys when needed.",
    match = ["cat .env"],
    not_match = ["cat .env.example"],
)

prefix_rule(
    pattern = ["printenv"],
    decision = "prompt",
    justification = "Full environment dumps can expose tokens; prefer checking specific variable names.",
    match = ["printenv"],
)
