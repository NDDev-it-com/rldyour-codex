.DS_Store
.env
.env.*
!.env.example
*.log
*.local
__pycache__/
.venv/
.coverage
coverage.xml
pytest.xml
*.stderr.log
.pytest_cache/
node_modules/
diagnostics/
dist/

# Browser / Webwright / Playwright CLI runtime artifacts
browser/**
!browser/
!browser/.gitkeep
.playwright-cli/
playwright-report/
test-results/
.webwright-runs/
outputs/webwright/
final_runs/
**/final_script_log.txt
**/trajectory.json
**/raw_responses.jsonl
**/screenshots/*.png
**/screenshots/*.jpg
**/screenshots/*.jpeg
**/screenshots/*.webp

# Serena project knowledge is trackable; runtime/cache state is not.
.serena/cache/
.serena/.gitignore
.serena/project.local.yml
.serena/.sync_marker
.serena/.serena_sync_state.json
.serena/.auto_sync_head
.serena/.active_workflow_intent.json
.serena/.dirty_stop_ack
.serena/.flow_sync_marker
.serena/.flow_post_task_state.json
