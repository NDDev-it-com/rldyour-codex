{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env bash -lc 'exec bash \"${PLUGIN_ROOT:?PLUGIN_ROOT is required}/hooks/session_start_dispatcher.sh\"'",
            "timeout": 15,
            "statusMessage": "Loading rldyour flow session context"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env bash -lc 'exec bash \"${PLUGIN_ROOT:?PLUGIN_ROOT is required}/hooks/post_tool_use_commit_advice.sh\"'",
            "timeout": 5,
            "statusMessage": "Checking rldyour commit advice"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env bash -lc 'exec bash \"${PLUGIN_ROOT:?PLUGIN_ROOT is required}/hooks/stop_lifecycle_dispatcher.sh\"'",
            "timeout": 20,
            "statusMessage": "Checking rldyour ordered lifecycle sync"
          }
        ]
      }
    ]
  }
}
