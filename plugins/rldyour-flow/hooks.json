{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env bash -lc 'exec bash \"${PLUGIN_ROOT:?PLUGIN_ROOT is required}/hooks/session_start_worktree_bootstrap.sh\"'",
            "timeout": 10,
            "statusMessage": "Bootstrapping rldyour fullrepo context"
          },
          {
            "type": "command",
            "command": "/usr/bin/env bash -lc 'exec bash \"${PLUGIN_ROOT:?PLUGIN_ROOT is required}/hooks/session_start_context.sh\"'",
            "timeout": 5,
            "statusMessage": "Loading rldyour flow session context"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env bash -lc 'exec bash \"${PLUGIN_ROOT:?PLUGIN_ROOT is required}/hooks/post_tool_use_commit_advice.sh\"'",
            "timeout": 5,
            "statusMessage": "Checking rldyour commit advice"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env bash -lc 'exec bash \"${PLUGIN_ROOT:?PLUGIN_ROOT is required}/hooks/stop_post_task_sync.sh\"'",
            "timeout": 10,
            "statusMessage": "Checking rldyour flow post-task sync"
          }
        ]
      }
    ]
  }
}
