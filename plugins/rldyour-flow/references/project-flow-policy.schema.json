{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rldyour.dev/schemas/project-flow-policy.schema.json",
  "title": "rldyour Flow project policy",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version"],
  "properties": {
    "schema_version": { "const": 1 },
    "profile": { "type": "string" },
    "description": { "type": "string" },
    "ownership": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "owned_by_user": { "type": "boolean" },
        "remote_owner": { "type": "string" },
        "destructive_git_requires_explicit_user_confirmation": { "type": "boolean" },
        "remote_branch_delete_requires_explicit_user_confirmation": { "type": "boolean" },
        "force_push_requires_explicit_user_confirmation": { "type": "boolean" }
      }
    },
    "operating_system": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "target": { "enum": ["auto", "macos", "linux", "windows", "wsl"] },
        "install_profile": {
          "enum": ["auto", "macos-standard", "macos-cmux-orchestrator", "linux-standard", "windows-standard", "wsl-standard"]
        }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": { "enum": ["standard", "orchestrator"] },
        "agent_role": { "enum": ["auto", "standalone", "orchestrator", "worker"] },
        "default_agent": { "enum": ["codex", "claude", "opencode"] },
        "worker_agents": { "$ref": "#/$defs/stringList" },
        "worker_count_min": { "type": "integer", "minimum": 0 },
        "worker_count_max": { "type": "integer", "minimum": 0 },
        "task_delegation": { "enum": ["direct", "explicit-orchestrator-only"] }
      }
    },
    "cmux": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "install_method": { "enum": ["auto", "brew-cask", "dmg", "manual"] },
        "global_config_path": { "type": "string" },
        "project_config_path": { "type": "string" },
        "install_hooks": { "type": "boolean" },
        "install_skills": { "type": "boolean" },
        "auto_resume_agent_sessions": { "type": "boolean" },
        "agent_hibernation_enabled": { "type": "boolean" },
        "socket_control_mode": { "enum": ["cmuxOnly"] },
        "workspace_layout": { "type": "string" },
        "version_policy": { "const": "latest-compatible" }
      }
    },
    "orchestrator": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "agent": { "enum": ["codex", "claude", "opencode"] },
        "user_facing_only": { "type": "boolean" },
        "owns_task_delegation": { "type": "boolean" },
        "owns_commits": { "type": "boolean" },
        "owns_push": { "type": "boolean" },
        "owns_system_install": { "type": "boolean" },
        "worker_permissions": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "commit": { "enum": ["forbidden", "forbidden-unless-delegated", "delegated"] },
            "push": { "enum": ["forbidden", "delegated"] },
            "system_install": { "enum": ["forbidden", "delegated"] },
            "branch_cleanup": { "enum": ["forbidden", "delegated"] }
          }
        },
        "concurrency": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "default_strategy": { "enum": ["single-writer", "worktree-per-worker"] },
            "read_only_workers_same_worktree": { "type": "boolean" },
            "write_workers_require_worktree_or_file_scope": { "type": "boolean" },
            "parallel_same_file_edits": { "const": "forbidden" },
            "commit_owner": { "enum": ["orchestrator", "delegated-worker"] }
          }
        }
      }
    },
    "branches": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allowed_work_branches": { "$ref": "#/$defs/stringList" },
        "protected_branches": { "$ref": "#/$defs/stringList" },
        "default_base_branch": { "type": "string" },
        "default_integration_branch": { "type": "string" }
      }
    },
    "normal_branch_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "agent_files": { "enum": ["allowed", "strict"] },
        "ai_marker_additions": { "enum": ["allowed", "strict"] },
        "instruction_docs": { "enum": ["tracked-main", "disabled"] },
        "runtime_markers": { "const": "forbidden" },
        "secrets": { "const": "forbidden" }
      }
    },
    "instruction_docs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": { "enum": ["tracked-main", "disabled"] },
        "codex": { "type": "string" },
        "claude": { "type": "string" },
        "opencode": { "type": "string" }
      }
    },
    "serena": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": { "enum": ["enabled", "disabled"] },
        "memory_storage": { "enum": ["tracked-main", "disabled"] },
        "allow_memory_commits": { "type": "boolean" },
        "forbid_runtime_markers": { "type": "boolean" }
      }
    },
    "branch_cleanup": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": { "enum": ["disabled", "advisory", "strict"] },
        "block_stop": { "type": "boolean" },
        "delete_local_branches": { "type": "boolean" },
        "delete_remote_branches": { "type": "boolean" },
        "workflow_branch_prefixes": { "$ref": "#/$defs/stringList" },
        "blocking_prefixes": { "$ref": "#/$defs/stringList" },
        "protected_branches": { "$ref": "#/$defs/stringList" }
      }
    },
    "stop_hook": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "block_on_dirty_source": { "type": "boolean" },
        "block_on_ahead_behind": { "type": "boolean" },
        "block_on_branch_cleanup": { "type": "boolean" },
        "allow_same_fingerprint_after_report": { "type": "boolean" }
      }
    }
  },
  "$defs": {
    "stringList": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    }
  }
}
